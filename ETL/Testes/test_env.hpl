  </order>
  <transform>
    <name>orders</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>north</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  order_id
, customer_id
, employee_id
, order_date
, required_date
, shipped_date
, ship_via
, freight
, ship_name
, ship_address
, ship_city
, ship_region
